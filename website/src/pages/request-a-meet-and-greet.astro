---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import LeadForm from '../components/LeadForm.astro';
import Steps from '../components/Steps.astro';
---

<BaseLayout title="Request a Meet & Greet — Paws on Longmeadow">
  <Hero
    title="Every Great Stay Starts Here"
    subtitle="Before any booking, every new client starts with a free Meet & Greet. It's relaxed, and it's the most important step we take together."
  />
  <section>
    <div class="container">
      <LeadForm />
    </div>
  </section>
  <Steps
    heading="What happens after you submit"
    steps={[
      'We review your request and reach out within 24 hours to schedule your Meet & Greet.',
      'We meet at our place or yours, depending on the service.',
      "If it's a great fit, we schedule a trial visit.",
      "After the trial, you're all set and your personal booking link is waiting in your inbox.",
    ]}
  />
</BaseLayout>
