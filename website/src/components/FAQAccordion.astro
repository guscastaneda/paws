---
import { getCollection } from 'astro:content';

const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);
const groups = [...new Set(faqs.map((f) => f.data.group))];
---

<div class="faq container">
  {
    groups.map((g) => (
      <section class="group">
        <h3>{g}</h3>
        {faqs
          .filter((f) => f.data.group === g)
          .map(({ data }) => (
            <details>
              <summary>{data.question}</summary>
              <p>{data.answer}</p>
            </details>
          ))}
      </section>
    ))
  }
</div>

<style>
  .faq { display: grid; gap: 2rem; }
  .group h3 { font-size: 1.15rem; color: var(--green-deep); margin-bottom: 0.75rem; }
  details { border-bottom: 1px solid var(--line); padding: 0.75rem 0; }
  summary {
    cursor: pointer;
    font-weight: 500;
    list-style: none;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: '+'; color: var(--green); font-size: 1.2rem; line-height: 1; }
  details[open] summary::after { content: '−'; }
  details p { color: var(--muted); margin-top: 0.6rem; max-width: 64ch; }
  summary:focus-visible { outline: 2px solid var(--green); outline-offset: 2px; }
</style>
