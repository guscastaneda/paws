---
// Lean top nav + the primary conversion CTA. Mobile nav is a build TODO.
const nav = [
  { label: 'About', href: '/about' },
  { label: 'Our Home', href: '/our-home' },
  { label: 'Services & Pricing', href: '/services' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand">Paws on Longmeadow</a>
    <nav class="nav">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
    </nav>
    <a href="/request-a-meet-and-greet" class="btn btn-primary">Request a Meet &amp; Greet</a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .bar { display: flex; align-items: center; gap: 1.5rem; padding-block: 0.9rem; }
  .brand {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--green-deep);
    text-decoration: none;
  }
  .nav { display: flex; gap: 1.1rem; margin-left: auto; }
  .nav a { color: var(--ink); text-decoration: none; font-size: 0.9rem; }
  .nav a:hover { color: var(--green); }
  @media (max-width: 860px) {
    .nav { display: none; } /* TODO: mobile menu */
  }
</style>
